# GitHub API Configuration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPOS=LanNguyenSi/agent-planforge,LanNguyenSi/scaffoldkit,LanNguyenSi/agent-ops-dashboard

# Gateway Auth (shared bearer token; gateway loud-fails 503 when unset)
# Generate a real one, e.g.: openssl rand -hex 32
GATEWAY_TOKEN=changeme-dev-only
# Comma-separated CORS allowlist; default is http://localhost:3000
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000
