# Environment variables for production deployment
# Copy this file to .env.production and fill in the actual values

# GitHub API Configuration
# Generate a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo, actions:read
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Repositories to Monitor
# Comma-separated list of owner/repo pairs
# Example: LanNguyenSi/telerithm,LanNguyenSi/agent-ops-dashboard,LanNguyenSi/triologue
GITHUB_REPOS=

# Triologue API Configuration
# URL to Triologue health endpoint for agent status monitoring
# Default: https://opentriologue.ai/gateway/health
TRIOLOGUE_API_URL=https://opentriologue.ai/gateway/health

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=Agent Ops Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: Custom Port (default: 3000)
# PORT=3000
