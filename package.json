{
  "name": "agent-ops-dashboard",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/dashboard",
    "dev:gateway": "npm run dev --workspace=packages/gateway",
    "dev:all": "npm run dev --workspace=apps/dashboard & npm run dev --workspace=packages/gateway",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present"
  },
  "overrides": {
    "ip-address": "^10.1.1",
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  }
}
